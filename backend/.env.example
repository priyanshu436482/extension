# Choose your AI provider: "openai", "gemini", or "groq" (default: openai)
AI_PROVIDER=openai

# OpenAI API Key (required if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-3.5-turbo)
# OPENAI_MODEL=gpt-3.5-turbo

# Gemini API Key (required if using Gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model (optional, defaults to gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Groq API Key (required if using Groq) — https://console.groq.com/keys
GROQ_API_KEY=gsk-your-groq-api-key-here

# Groq Model (optional, defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# FreeLLMAPI (local AI router) — https://freellmapi.com
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_API_KEY=freellmapi-your-unified-key
FREELLMAPI_MODEL=auto

# Server port (optional, defaults to 3000)
